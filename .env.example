# Option 1: one ready-to-use URI. Encode special characters in the password.
MONGO_URI=mongodb+srv://user:encoded_password@cluster.mongodb.net/?retryWrites=true&w=majority&appName=Cluster1

# Option 2: parts. main.py can build URI from these if MONGO_URI is absent.
# MONGO_USER=spotify_user
# MONGO_PASSWORD=my@pass#123
# MONGO_HOST=cluster1.xxxxx.mongodb.net
# MONGO_DB=spotify
# DATASET_PATH=dataset.csv
